    <limit>0</limit>
    <sql>SELECT
    t.id_client,
    t.id_agent,
    t.id_bien,
    b.id_projet,
    t.date_transaction,
    t.montant,
    1 AS nombre_transaction
FROM transactions t
JOIN biens_immobilier b
    ON b.id_bien = t.id_bien;</sql>
